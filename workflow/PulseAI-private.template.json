    {
      "parameters": {
        "jsCode": "const items = $json.rss.channel.item || [];\n\n// get feed title dynamically (like \"BBC News\", \"NPR\", etc.)\nconst sourceName = $json.rss.channel.title || \"Unknown Source\";\n\nreturn items.slice(0, 5).map(article => ({\n  json: {\n    source: sourceName,\n    title: article.title || \"\",\n    link: article.link || \"\",\n    description: article.description || \"\"\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        16
      ],
      "id": "fa4c95ef-2499-4f09-8383-9a1ad17ee54f",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "const items = $json.feed?.entry || [];\nconst rawSource = $json.feed?.title;\n\nconst sourceName =\n  typeof rawSource === \"object\"\n    ? rawSource._ || \"The Verge\"\n    : rawSource || \"The Verge\";\n\nreturn items.slice(0, 5).map(article => ({\n  json: {\n    source: sourceName,\n    title: article.title?._ || article.title || \"\",\n    link: Array.isArray(article.link)\n      ? (article.link.find(l => l.rel === \"alternate\")?.href || article.link[0]?.href || \"\")\n      : (article.link?.href || article.link || \"\"),\n    description:\n      article.summary?._ ||\n      article.summary ||\n      article.content?._ ||\n      article.content ||\n      \"\",\n    published: article.published || article.updated || \"\"\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
