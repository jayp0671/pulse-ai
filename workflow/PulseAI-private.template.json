    {
      "parameters": {
        "jsCode": "const prompt = `You are PulseAI, a market intelligence analyst.\n\nYour job:\n1. Identify the 5 most important stories overall\n2. Summarize each in 2-3 sentences\n3. Flag stories related to AI, technology, business, or geopolitics\n4. For each story, include:\n- Headline\n- Source\n- Summary\n- Why it matters\n5. Keep the tone crisp, professional, and easy to skim in an email\n\nArticles:\n\n${$json.compiledArticles}`;\n\nreturn [\n  {\n    json: {\n      requestBody: JSON.stringify({\n        contents: [\n          {\n            parts: [\n              {\n                text: prompt\n              }\n            ]\n          }\n        ]\n      })\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
