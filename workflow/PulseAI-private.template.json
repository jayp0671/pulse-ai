    {
      "parameters": {
        "jsCode": "const articles = $input.all();\n\nconst formattedText = articles.map((item, index) => {\n  const a = item.json;\n  return `${index + 1}. Source: ${a.source}\nTitle: ${a.title}\nPublished: ${a.published}\nSummary: ${a.description}\nLink: ${a.link}`;\n}).join('\\n\\n');\n\nreturn [\n  {\n    json: {\n      articleCount: articles.length,\n      compiledArticles: formattedText\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
